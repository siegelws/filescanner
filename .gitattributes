# Default: let Git decide
* text=auto

# Files that MUST have LF endings (Linux shell scripts, Dockerfiles, configs)
*.sh        text eol=lf
*.py        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.conf      text eol=lf
*.toml      text eol=lf
*.ini       text eol=lf
*.yar       text eol=lf
*.yara      text eol=lf
*.mako      text eol=lf
Dockerfile  text eol=lf
Dockerfile.* text eol=lf
.env*       text eol=lf

# Windows-only files keep CRLF
*.ps1       text eol=crlf
*.bat       text eol=crlf
*.cmd       text eol=crlf
