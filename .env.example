# Copy to .env and fill in values before running `docker compose up`.

# --- core secrets ---------------------------------------------------------
POSTGRES_USER=scanner
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=scanner

# openssl rand -hex 32
SECRET_KEY=replace_with_openssl_rand_hex_32

# --- engine API keys ------------------------------------------------------
# Get free keys at:
#   VirusTotal:       https://www.virustotal.com/gui/my-apikey
#   Hybrid Analysis:  https://www.hybrid-analysis.com/apikeys/info
#   MetaDefender:     https://metadefender.opswat.com/account/api-key
VIRUSTOTAL_API_KEY=
METADEFENDER_API_KEY=
HYBRID_ANALYSIS_API_KEY=

# --- limits / public URLs -------------------------------------------------
MAX_UPLOAD_BYTES=209715200
PUBLIC_API_URL=https://your-domain.com
PUBLIC_WS_URL=wss://your-domain.com

# --- optional ------------------------------------------------------------
# YARA rules are bundled at /rules inside the container; override only if
# you mount your own rule pack.
# YARA_RULES_DIR=/rules
