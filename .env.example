# Copy to .env and fill in values before running docker compose.

POSTGRES_USER=scanner
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=scanner

# 64+ random hex chars: openssl rand -hex 32
SECRET_KEY=replace_with_openssl_rand_hex_32

# Shared bearer token between API/worker and every VM agent.
# Rotate periodically. openssl rand -hex 32
VM_AGENT_TOKEN=replace_with_openssl_rand_hex_32

# 200 MiB default upload cap
MAX_UPLOAD_BYTES=209715200

# Path to VMware's vmrun CLI on the worker host (used by VM orchestrator).
# Linux:   /usr/bin/vmrun
# Windows: C:\Program Files (x86)\VMware\VMware VIX\vmrun.exe
VMRUN_PATH=/usr/bin/vmrun

PUBLIC_API_URL=http://localhost:8000
PUBLIC_WS_URL=ws://localhost:8000
